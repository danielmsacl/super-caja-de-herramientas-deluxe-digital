<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CajaHerramientas.Vistas.Nivel"
             Title="Nivel"
             BackgroundColor="#F0F4F8">

    <VerticalStackLayout Padding="20" Spacing="18" VerticalOptions="Center">

        <Border BackgroundColor="White"
                Stroke="Transparent"
                Padding="18">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="16"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="12" Opacity="0.08"/>
            </Border.Shadow>

            <VerticalStackLayout Spacing="14" HorizontalOptions="Center">
                <Label Text="Nivel de Burbuja"
                       FontSize="26"
                       FontAttributes="Bold"
                       TextColor="#1A1A2E"
                       HorizontalOptions="Center"/>

                <GraphicsView x:Name="NivelView"
                              WidthRequest="320"
                              HeightRequest="320"
                              HorizontalOptions="Center"/>

                <Label x:Name="EstadoLabel"
                       Text="Coloca el celular sobre una superficie"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="#888888"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>

                <Label x:Name="AnguloLabel"
                       Text="Inclinacion: 0.0 grados"
                       FontSize="18"
                       TextColor="#1A1A2E"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Border>

    </VerticalStackLayout>

</ContentPage>
