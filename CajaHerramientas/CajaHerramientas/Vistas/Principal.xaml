<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CajaHerramientas.Vistas.Principal"
             BackgroundColor="#F0F4F8">

    <VerticalStackLayout Spacing="10" VerticalOptions="Center" HorizontalOptions="Center">

        <Image Source="logo.png"
               WidthRequest="300"
               HeightRequest="160"
               Aspect="AspectFit"
               HorizontalOptions="Center"/>

        <Button x:Name="BrujulaButton"
            Text="Brújula"
            FontSize="24"
            FontAttributes="Bold"
            BackgroundColor="#3498DB"
            TextColor="White"
            CornerRadius="15"
            WidthRequest="200"
            HeightRequest="80"
            Clicked="OnBrujulaClicked"/>

        <Button x:Name="ReglaButton"
            Text="Regla"
            FontSize="24"
            FontAttributes="Bold"
            BackgroundColor="#27AE60"
            TextColor="White"
            CornerRadius="15"
            WidthRequest="200"
            HeightRequest="80"
            Clicked="OnReglaClicked"/>

        <Button x:Name="NivelButton"
            Text="Nivel"
            FontSize="24"
            FontAttributes="Bold"
            BackgroundColor="#E67E22"
            TextColor="White"
            CornerRadius="15"
            WidthRequest="200"
            HeightRequest="80"
            Clicked="OnNivelClicked"/>
        
        <Button x:Name="LupaButton"
            Text="Lupa"
            FontSize="24"
            FontAttributes="Bold"
            BackgroundColor="#E67E22"
            TextColor="White"
            CornerRadius="15"
            WidthRequest="200"
            HeightRequest="80"
            Clicked="OnLupaClicked"/>

        <Button x:Name="LinternaButton"
            Text="Linterna"
            FontSize="24"
            FontAttributes="Bold"
            BackgroundColor="#E67E22"
            TextColor="White"
            CornerRadius="15"
            WidthRequest="200"
            HeightRequest="80"
            Clicked="OnLinternaClicked"/>

        <Image x:Name="ReglaImagen"
               Source="regla.png"
               WidthRequest="200"
               HeightRequest="200"
               Aspect="AspectFit"
               HorizontalOptions="Center"
               Margin="0,10,0,0"
               IsVisible="False"/>

    </VerticalStackLayout>


</ContentPage>