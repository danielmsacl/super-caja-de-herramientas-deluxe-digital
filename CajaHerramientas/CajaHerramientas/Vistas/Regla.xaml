<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CajaHerramientas.Vistas.Regla"
             Title="Regla"
             BackgroundColor="Black">

    <Grid>
        <!-- Camera preview container (populated in code-behind) -->
        <Grid x:Name="CameraContainer"/>

        <!-- Overlay for ruler drawing -->
        <GraphicsView x:Name="RulerOverlay"
                       BackgroundColor="Transparent"
                       InputTransparent="False"/>

        <!-- Bottom controls panel -->
        <Border VerticalOptions="End"
                HorizontalOptions="Fill"
                BackgroundColor="#CC1A1A2E"
                Stroke="Transparent"
                Padding="16"
                Margin="10,0,10,20">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="16"/>
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="12">

                <Label x:Name="StatusLabel"
                       Text="Presiona Iniciar y avanza con el dispositivo"
                       FontSize="14"
                       TextColor="#AAAAAA"
                       HorizontalOptions="Center"/>

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                    <Label Text="📏 Distancia:"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="White"
                           VerticalOptions="Center"/>
                    <Label x:Name="DistanciaLabel"
                           Text="0.0 cm"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="#27AE60"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="16">
                    <Button x:Name="IniciarButton"
                            Text="▶ Iniciar"
                            FontSize="16"
                            FontAttributes="Bold"
                            BackgroundColor="#3498DB"
                            TextColor="White"
                            CornerRadius="10"
                            WidthRequest="130"
                            HeightRequest="48"
                            Clicked="OnIniciarClicked"/>
                    <Button x:Name="FinalizarButton"
                            Text="■ Finalizar"
                            FontSize="16"
                            FontAttributes="Bold"
                            BackgroundColor="#E74C3C"
                            TextColor="White"
                            CornerRadius="10"
                            WidthRequest="130"
                            HeightRequest="48"
                            IsEnabled="False"
                            Clicked="OnFinalizarClicked"/>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
