<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CajaHerramientas.Vistas.Regla"
             Title="Regla"
             BackgroundColor="#1A1A2E">

    <Grid RowDefinitions="Auto,*,Auto">

        <VerticalStackLayout Grid.Row="0" Padding="20,50,20,10" Spacing="6">
            <Label Text="Regla"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"/>
            <Label x:Name="ScreenWidthLabel"
                   Text="..."
                   FontSize="15"
                   TextColor="#7F8C8D"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <GraphicsView x:Name="RulerView"
                       Grid.Row="1"
                       BackgroundColor="#16213E"
                       HorizontalOptions="Fill"
                       VerticalOptions="Center"
                       HeightRequest="160"/>

        <Border Grid.Row="2"
                VerticalOptions="End"
                HorizontalOptions="Fill"
                BackgroundColor="#CC1A1A2E"
                Stroke="Transparent"
                Padding="20"
                Margin="10,0,10,20">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="16"/>
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="8">
                <Label Text="Coloca el objeto desde el borde izquierdo de la pantalla"
                       FontSize="14"
                       TextColor="#BDC3C7"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>
                <Label Text="La regla muestra centímetros reales según el tamaño de tu pantalla"
                       FontSize="12"
                       TextColor="#7F8C8D"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>
        </Border>

    </Grid>

</ContentPage>
